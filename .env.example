# Copy this file to .env and fill in your values
SECRET_KEY=change-me-to-a-random-string

# Etsy Open API v3 credentials
# Obtain from https://www.etsy.com/developers/your-apps
ETSY_API_KEY=
ETSY_API_SECRET=
ETSY_ACCESS_TOKEN=
ETSY_SHOP_ID=
# Etsy taxonomy ID for your product category (default 2078 = Digital prints)
# See https://www.etsy.com/developers/documentation/reference/taxonomy for valid IDs
ETSY_TAXONOMY_ID=2078

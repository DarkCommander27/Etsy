# AI Provider Settings (use at least one)
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Optional: Default AI provider (gemini, groq, or ollama)
DEFAULT_AI_PROVIDER=gemini

# Ollama runs locally — no API key needed
# Default URL: http://localhost:11434

# Etsy Integration (optional — for one-click publishing)
# Create a free app at https://www.etsy.com/developers/register
# Set redirect URI to: http://localhost:3000/api/etsy/callback
ETSY_API_KEY=your-etsy-keystring-here
# Etsy taxonomy ID for your product category (default 2078 = Digital prints)
# See https://www.etsy.com/developers/documentation/reference/taxonomy for valid IDs
ETSY_TAXONOMY_ID=2078
